{
  "name": "maidb-data",
  "version": "0.0.0",
  "description": "A starter for creating a TypeScript package.",
  "homepage": "https://github.com/author/library#readme",
  "bugs": {
    "url": "https://github.com/author/library/issues"
  },
  "license": "MIT",
  "author": "Author Name <author.name@mail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/author/library.git"
  },
  "files": [
    "dist",
    "data/songs"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./data/songs/songs.json": "./data/songs/songs.json",
    "./data/songs/metadata.json": "./data/songs/metadata.json",
    "./data/songs/latest-only.json": "./data/songs/latest-only.json",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "append-songs": "tsx src/scripts/append-songs.ts",
    "create-images": "tsx src/scripts/create-image-assets.ts",
    "upload": "tsx src/scripts/upload-to-s3.ts",
    "create-slugs": "tsx src/scripts/create-slugs.ts",
    "finalize": "tsx src/scripts/finalize-songs-json.ts",
    "sync": "tsx src/scripts/sync.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "catalog:",
    "@resvg/resvg-js": "catalog:",
    "dotenv": "catalog:",
    "fuse.js": "catalog:",
    "nanoid": "catalog:",
    "satori": "catalog:",
    "sharp": "catalog:",
    "tsx": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "bumpp": "^11.0.1",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.11"
  }
}
