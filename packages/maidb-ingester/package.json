{
  "name": "maidb-ingester",
  "version": "0.0.0",
  "description": "A starter for creating a TypeScript package.",
  "homepage": "https://github.com/author/library#readme",
  "bugs": {
    "url": "https://github.com/author/library/issues"
  },
  "license": "MIT",
  "author": "Author Name <author.name@mail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/author/library.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "scrape": "tsx src/scrape-maimai-songs.ts",
    "create-images": "tsx src/create-image-assets.ts",
    "upload": "tsx src/upload-to-s3.ts",
    "ingest": "tsx src/ingest-to-convex.ts",
    "total-reset": "tsx src/total-reset.ts",
    "backfill:find": "tsx src/backfill-missing-images.ts",
    "backfill:images": "tsx src/create-image-assets.ts --backfill",
    "backfill:upload": "tsx src/upload-to-s3.ts --backfill",
    "backfill:ingest": "tsx src/ingest-image-backfill-convex.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "catalog:",
    "@resvg/resvg-js": "catalog:",
    "backend": "workspace:*",
    "convex": "catalog:",
    "dotenv": "catalog:",
    "nanoid": "^5.1.5",
    "satori": "catalog:",
    "sharp": "^0.34.2",
    "tsx": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "bumpp": "^11.0.1",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.11"
  }
}
